<div class="min-h-screen bg-gray-100">
  <header class="bg-blue-600 text-white p-4">
    <h1 class="text-2xl font-bold text-center md:text-left">Vote Confirmation</h1>
  </header>
  <main class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    <% if flash[:notice] %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
        <%= flash[:notice] %>
      </div>
    <% end %>
    <p>Your vote has been recorded successfully.</p>
    <div class="mt-4">
      <%= link_to 'Cast Another Vote', new_budget_cycle_vote_path(@budget_cycle), class: "bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600 mr-2" %>
      <%= link_to 'Back to Budget Cycles', budget_cycles_path, class: "bg-gray-500 text-white py-2 px-4 rounded hover:bg-gray-600" %>
    </div>
  </main>
</div>