<div id="flash_container" data-controller="flash" class="fixed top-4 right-4 z-50 max-w-sm">
  <% if notice %>
    <p data-flash-target="message" class="bg-green-100 text-green-800 p-4 rounded shadow mb-2"><%= notice %></p>
  <% end %>
  <% if alert %>
    <p data-flash-target="message" class="bg-red-100 text-red-800 p-4 rounded shadow"><%= alert %></p>
  <% end %>
</div>