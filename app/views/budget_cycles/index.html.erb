<div class="min-h-screen bg-gray-100">
  <header class="bg-blue-600 text-white p-4">
    <h1 class="text-2xl font-bold text-center md:text-left">Available Budget Cycles</h1>
  </header>
  <main class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    <% if @budget_cycles.empty? %>
      <p class="text-gray-700">No active budget cycles available for voting.</p>
    <% else %>
      <h2 class="text-xl font-semibold mb-4">Select a Budget Cycle to Vote</h2>
      <ul class="space-y-4">
        <% @budget_cycles.each do |budget_cycle| %>
          <li class="bg-white p-4 rounded shadow">
            <h3 class="text-lg font-medium"><%= budget_cycle.name %></h3>
            <p class="text-gray-600">Total Budget: <%= number_to_currency(budget_cycle.total_budget) %></p>
            <p class="text-gray-600">Active From: <%= budget_cycle.start_date %> to <%= budget_cycle.end_date %></p>
            <% if budget_cycle.current_voting_phase %>
              <%= link_to 'Vote Now', new_budget_cycle_vote_path(budget_cycle), class: "inline-block bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600 mt-5" %>
            <% else %>
              <p class="text-gray-600">No active voting phase at this time.</p>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </main>
</div>