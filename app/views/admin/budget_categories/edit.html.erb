<h1 class="text-2xl font-bold mb-4">Edit Budget Category</h1>
<%= form_with model: @budget_category, url: admin_budget_category_path(@budget_category), local: true, class: "space-y-4" do |form| %>
  <% if @budget_category.errors.any? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
      <h2><%= pluralize(@budget_category.errors.count, "error") %> prohibited this category from being saved:</h2>
      <ul class="list-disc ml-5">
        <% @budget_category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= form.label :name, class: 'block text-sm font-medium text-gray-700' %>
    <%= form.text_field :name, class: 'mt-1 block w-full border-gray-300 rounded-md shadow-sm' %>
  </div>
  <div>
    <%= form.label :spending_limit_percentage, class: 'block text-sm font-medium text-gray-700' %>
    <%= form.number_field :spending_limit_percentage, step: 0.1, class: 'mt-1 block w-full border-gray-300 rounded-md shadow-sm' %>
  </div>
  <div>
    <%= form.label :budget_cycle_id, 'Budget Cycle', class: 'block text-sm font-medium text-gray-700' %>
    <%= form.select :budget_cycle_id, BudgetCycle.all.map { |c| [c.name, c.id] }, { selected: @budget_cycle&.id }, class: 'mt-1 block w-full border-gray-300 rounded-md shadow-sm' %>
  </div>
  <%= form.submit 'Update Category', class: 'bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600' %>
<% end %>