<div class="min-h-screen bg-gray-100">
  <header class="bg-blue-600 text-white p-4">
    <h1 class="text-2xl font-bold text-center md:text-left">Edit Budget Category</h1>
  </header>
  <main class="max-w-lg mx-auto p-4 sm:p-6 lg:p-8">
    <% if notice %>
      <p id="notice" class="text-green-600 mb-4 bg-green-100 p-3 rounded transition-opacity duration-500" data-controller="fade"><%= notice %></p>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const notice = document.getElementById('notice');
          if (notice) {
            setTimeout(() => {
              notice.style.display = 'none';
              setTimeout(() => notice.remove(), 500);
            }, 3000);
          }
        });
      </script>
    <% end %>
    <%= form_with model: @budget_category, url: admin_budget_category_path(@budget_category), local: true, class: "space-y-4" do |form| %>
      <% if @budget_category.errors.any? %>
        <div class="bg-red-100 text-red-700 p-4 rounded">
          <h2><%= pluralize(@budget_category.errors.count, "error") %> prohibited this category from being saved:</h2>
          <ul class="list-disc pl-5">
            <% @budget_category.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div>
        <%= form.label :name, class: "block text-gray-700" %>
        <%= form.text_field :name, class: "w-full p-2 border rounded" %>
      </div>
      <div>
        <%= form.label :spending_limit_percentage, class: "block text-gray-700" %>
        <%= form.number_field :spending_limit_percentage, step: 0.01, min: 0, max: 100, class: "w-full p-2 border rounded" %>
      </div>
      <div>
        <%= form.submit "Update Category", class: "bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600" %>
      </div>
    <% end %>
    <%= link_to "Back", admin_budget_categories_path, class: "text-blue-500 hover:underline" %>
  </main>
</div>