<%= render 'shared/nav' %>
<h1 class="text-2xl font-bold mb-4">Budget Categories</h1>
<%= form_with url: admin_budget_categories_path, method: :get, local: true, class: "mb-4" do |form| %>
  <div class="flex space-x-4">
    <%= form.label :search, 'Search by name', class: 'block text-sm font-medium text-gray-700' %>
    <%= form.text_field :search, value: params[:search], class: 'mt-1 block w-1/4 border-gray-300 rounded-md shadow-sm' %>
    <%= form.label :budget_cycle_id, 'Budget Cycle', class: 'block text-sm font-medium text-gray-700' %>
    <%= form.select :budget_cycle_id, BudgetCycle.all.map { |c| [c.name, c.id] }, { include_blank: 'All Cycles' }, class: 'mt-1 block w-1/4 border-gray-300 rounded-md shadow-sm' %>
    <%= form.submit 'Filter', class: 'bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600' %>
  </div>
<% end %>
<% if @budget_cycle %>
  <p class="mb-2">Showing categories for <%= @budget_cycle.name %></p>
<% end %>
<%= link_to 'New Category', new_admin_budget_category_path(budget_cycle_id: params[:budget_cycle_id]), class: 'bg-green-500 text-blue-500 py-2 px-4 rounded hover:bg-green-600 mb-4 inline-block' %>
<table class="table-auto w-full border-collapse">
  <thead>
    <tr class="bg-gray-200">
      <th class="border px-4 py-2">Name</th>
      <th class="border px-4 py-2">Spending Limit (%)</th>
      <th class="border px-4 py-2">Utilization (%)</th>
      <th class="border px-4 py-2">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @budget_categories.each do |category| %>
      <tr>
        <td class="border px-4 py-2"><%= category.name %></td>
        <td class="border px-4 py-2"><%= category.spending_limit_percentage %></td>
        <td class="border px-4 py-2"><%= category.utilization_rate(@budget_cycle || category.budget_cycle) %></td>
        <td class="border px-4 py-2">
          <%= link_to 'Edit', edit_admin_budget_category_path(category), class: 'text-blue-500 hover:underline' %>
          <%= link_to 'Delete', admin_budget_category_path(category), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline ml-2' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>