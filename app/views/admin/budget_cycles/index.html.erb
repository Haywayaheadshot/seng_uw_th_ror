<div class="min-h-screen bg-gray-100">
  <header class="bg-blue-600 text-white p-4">
    <h1 class="text-2xl font-bold text-center md:text-left">Budget Cycles</h1>
  </header>
  <main class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    <div class="overflow-x-auto">
      <table class="min-w-full bg-white shadow-md rounded-lg">
        <thead class="bg-gray-200">
          <tr>
            <th class="py-2 px-4 text-left">Name</th>
            <th class="py-2 px-4 text-left">Total Budget</th>
            <th class="py-2 px-4 text-left">Start Date</th>
            <th class="py-2 px-4 text-left">End Date</th>
            <th class="py-2 px-4 text-left">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @budget_cycles.each do |cycle| %>
            <tr class="border-b">
              <td class="py-2 px-4"><%= cycle.name %></td>
              <td class="py-2 px-4"><%= number_to_currency(cycle.total_budget) %></td>
              <td class="py-2 px-4"><%= cycle.start_date %></td>
              <td class="py-2 px-4"><%= cycle.end_date %></td>
              <td class="py-2 px-4">
                <%= link_to 'Show Phases', admin_budget_cycle_voting_phases_path(cycle), class: "text-blue-500 hover:underline" %>
                <%= link_to 'Edit', edit_admin_budget_cycle_path(cycle), class: "text-blue-500 hover:underline" %>
                <%= link_to 'Delete', admin_budget_cycle_path(cycle), method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: "text-red-500 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="mt-4">
      <%= link_to 'New Budget Cycle', new_admin_budget_cycle_path, class: "block bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600 text-center md:text-left" %>
      <%= link_to 'Dashboard', admin_dashboard_path, class: "block bg-gray-500 text-white py-2 px-4 rounded hover:bg-gray-600 text-center md:text-left mt-2" %>
    </div>
  </main>
</div>