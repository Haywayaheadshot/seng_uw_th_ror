<%= render 'shared/nav' %>
<div style="display: flex; flex-direction: column; flex-gap: 10px"> 
  <h1 class="text-2xl font-bold mb-4">Budget Cycles</h1>
  <%= link_to 'New Budget Cycle', new_admin_budget_cycle_path, class: 'text-white bg-blue-500 py-2 px-4 rounded hover:bg-green-600 mb-4 inline-block', style: 'max-width: 200px' %> 
</div>
<table class="table-auto w-full border-collapse">
  <thead>
    <tr class="bg-gray-200">
      <th class="border px-4 py-2">Name</th>
      <th class="border px-4 py-2">Total Budget</th>
      <th class="border px-4 py-2">Start Date</th>
      <th class="border px-4 py-2">End Date</th>
      <th class="border px-4 py-2">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @budget_cycles.each do |cycle| %>
      <tr>
        <td class="border px-4 py-2"><%= cycle.name %></td>
        <td class="border px-4 py-2"><%= number_to_currency(cycle.total_budget) %></td>
        <td class="border px-4 py-2"><%= cycle.start_date %></td>
        <td class="border px-4 py-2"><%= cycle.end_date %></td>
        <td class="border px-4 py-2">
          <%= link_to 'Show', admin_budget_cycle_path(cycle), class: 'text-blue-500 hover:underline' %>
          <%= link_to 'Edit', edit_admin_budget_cycle_path(cycle), class: 'text-blue-500 hover:underline ml-2' %>
          <%= button_to 'Delete', admin_budget_cycle_path(cycle), method: :delete, class: 'text-red-500 hover:underline ml-2' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>