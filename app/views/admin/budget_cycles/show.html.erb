<%= render 'shared/nav' %>
<div class="container mx-auto p-4">
  <h1 class="text-2xl font-bold mb-4">Budget Cycle: <%= @budget_cycle.name %></h1>
  
  <div class="mb-4">
    <p><strong>Total Budget:</strong> <%= number_to_currency(@budget_cycle.total_budget) %></p>
    <p><strong>Start Date:</strong> <%= @budget_cycle.start_date %></p>
    <p><strong>End Date:</strong> <%= @budget_cycle.end_date %></p>
    <p><strong>Created At:</strong> <%= @budget_cycle.created_at.strftime('%B %d, %Y %I:%M %p') %></p>
    <p><strong>Updated At:</strong> <%= @budget_cycle.updated_at.strftime('%B %d, %Y %I:%M %p') %></p>
  </div>

  <div class="mb-4 space-x-2">
    <%= link_to 'Edit Cycle', edit_admin_budget_cycle_path(@budget_cycle), class: 'text-blue-500 hover:underline' %>
    <%= button_to 'Delete Cycle', admin_budget_cycle_path(@budget_cycle), method: :delete, class: 'text-red-500 hover:underline' %>
    <%= link_to 'Manage Projects', admin_budget_cycle_budget_projects_path(@budget_cycle), class: 'text-blue-500 hover:underline' %>
    <%= link_to 'Manage Phases', admin_budget_cycle_voting_phases_path(@budget_cycle), class: 'text-blue-500 hover:underline' %>
    <%= link_to 'Manage Categories', admin_budget_categories_path(budget_cycle_id: @budget_cycle.id), class: 'text-blue-500 hover:underline' %>
    <%= link_to 'Impact Report', admin_impact_report_path(@budget_cycle), class: 'text-blue-500 hover:underline' %>
    <%= link_to 'Manage Participants', admin_participants_path, class: 'text-blue-500 hover:underline' %>
  </div>

  <h2 class="text-xl font-semibold mb-2">Budget Categories</h2>
  <% if @budget_cycle.budget_categories.empty? %>
    <p class="text-gray-500">No categories assigned to this cycle.</p>
  <% else %>
    <table class="table-auto w-full border-collapse mb-4">
      <thead>
        <tr class="bg-gray-200">
          <th class="border px-4 py-2">Name</th>
          <th class="border px-4 py-2">Spending Limit (%)</th>
          <th class="border px-4 py-2">Utilization (%)</th>
          <th class="border px-4 py-2">Allocated Amount</th>
          <th class="border px-4 py-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @budget_cycle.budget_categories.each do |category| %>
          <tr>
            <td class="border px-4 py-2"><%= category.name %></td>
            <td class="border px-4 py-2"><%= category.spending_limit_percentage %></td>
            <td class="border px-4 py-2"><%= category.utilization_rate(@budget_cycle) %></td>
            <td class="border px-4 py-2"><%= number_to_currency(category.allocated_amount(@budget_cycle)) %></td>
            <td class="border px-4 py-2">
              <%= link_to 'Edit', edit_admin_budget_category_path(category), class: 'text-blue-500 hover:underline' %>
              <%= button_to 'Delete', admin_budget_category_path(category), method: :delete, class: 'text-red-500 hover:underline ml-2' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <h2 class="text-xl font-semibold mb-2">Budget Projects</h2>
  <% if @budget_cycle.budget_projects.empty? %>
    <p class="text-gray-500">No projects assigned to this cycle.</p>
  <% else %>
    <table class="table-auto w-full border-collapse mb-4 overflow-x-auto w-full" style="overflow: x-axis">
      <thead>
        <tr class="bg-gray-200">
          <th class="border px-4 py-2">Name</th>
          <th class="border px-4 py-2">Category</th>
          <th class="border px-4 py-2">Proposed Budget</th>
          <th class="border px-4 py-2">Estimated Beneficiaries</th>
          <th class="border px-4 py-2">Timeline</th>
          <th class="border px-4 py-2">Sustainability Score</th>
          <th class="border px-4 py-2">Approved</th>
          <th class="border px-4 py-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @budget_cycle.budget_projects.each do |project| %>
          <tr>
            <td class="border px-4 py-2"><%= project.name %></td>
            <td class="border px-4 py-2"><%= project.budget_category.name %></td>
            <td class="border px-4 py-2"><%= number_to_currency(project.proposed_budget) %></td>
            <td class="border px-4 py-2"><%= project.impact_metrics['estimated_beneficiaries'] || 'N/A' %></td>
            <td class="border px-4 py-2"><%= project.impact_metrics['timeline'] || 'N/A' %></td>
            <td class="border px-4 py-2"><%= project.impact_metrics['sustainability_score'] || 'N/A' %></td>
            <td class="border px-4 py-2"><%= project.approved ? 'Yes' : 'No' %></td>
            <td class="border px-4 py-2">
              <%= link_to 'Edit', edit_admin_budget_cycle_budget_project_path(@budget_cycle, project), class: 'text-blue-500 hover:underline' %>
              <%= button_to 'Delete', admin_budget_cycle_budget_project_path(@budget_cycle, project), method: :delete, class: 'text-red-500 hover:underline ml-2' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <h2 class="text-xl font-semibold mb-2">Voting Phases</h2>
  <% if @budget_cycle.voting_phases.empty? %>
    <p class="text-gray-500">No voting phases assigned to this cycle.</p>
  <% else %>
    <table class="table-auto w-full border-collapse mb-4">
      <thead>
        <tr class="bg-gray-200">
          <th class="border px-4 py-2">Name</th>
          <th class="border px-4 py-2">Status</th>
          <th class="border px-4 py-2">Start Date</th>
          <th class="border px-4 py-2">End Date</th>
          <th class="border px-4 py-2">Max Votes</th>
          <th class="border px-4 py-2">Minimum Age</th>
          <th class="border px-4 py-2">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @budget_cycle.voting_phases.each do |phase| %>
          <tr>
            <td class="border px-4 py-2"><%= phase.name %></td>
            <td class="border px-4 py-2"><%= phase.phase_status.humanize %></td>
            <td class="border px-4 py-2"><%= phase.start_date %></td>
            <td class="border px-4 py-2"><%= phase.end_date %></td>
            <td class="border px-4 py-2"><%= phase.voting_rules['max_votes'] || 'N/A' %></td>
            <td class="border px-4 py-2"><%= phase.participant_eligibility['min_age'] || 'N/A' %></td>
            <td class="border px-4 py-2">
              <%= link_to 'Show', admin_budget_cycle_voting_phase_path(@budget_cycle, phase), class: 'text-blue-500 hover:underline' %>
              <%= link_to 'Edit', edit_admin_budget_cycle_voting_phase_path(@budget_cycle, phase), class: 'text-blue-500 hover:underline ml-2' %>
              <%= button_to 'Delete', admin_budget_cycle_voting_phase_path(@budget_cycle, phase), method: :delete, class: 'text-red-500 hover:underline ml-2' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <%= link_to 'Back to Budget Cycles', admin_budget_cycles_path, class: 'text-blue-500 hover:underline' %>
</div>