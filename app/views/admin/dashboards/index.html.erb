<div class="min-h-screen bg-gray-100">
         <header class="bg-blue-600 text-white p-4">
           <h1 class="text-2xl font-bold text-center md:text-left">Admin Dashboard</h1>
         </header>
         <main class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
           <h2 class="text-xl font-semibold mb-4">Active Budget Cycles and Voting Phases</h2>
           <% if @budget_cycles.empty? %>
             <p class="text-gray-700">No active budget cycles available.</p>
           <% else %>
             <ul class="space-y-4">
               <% @budget_cycles.each do |cycle| %>
                 <li class="bg-white p-4 rounded shadow">
                   <h3 class="text-lg font-medium">Budget Cycle: <%= cycle.name %></h3>
                   <p class="text-gray-600">Total Budget: <%= number_to_currency(cycle.total_budget) %></p>
                   <p class="text-gray-600">Active From: <%= cycle.start_date %> to <%= cycle.end_date %></p>
                   <% if cycle.current_voting_phase %>
                     <p class="text-gray-600">Current Phase: <%= cycle.current_voting_phase.name %> (<%= cycle.current_voting_phase.phase_status %>)</p>
                   <% else %>
                     <p class="text-gray-600">No active voting phase.</p>
                   <% end %>
                 </li>
               <% end %>
             </ul>
           <% end %>

           <h2 class="text-xl font-semibold mt-8 mb-4">Voting Phase Reports</h2>
           <% if @voting_reports.empty? %>
             <p class="text-gray-700">No active voting phases available.</p>
           <% else %>
             <% @voting_reports.each do |report| %>
               <%= render partial: 'voting_phase_report', locals: { report: report } %>
             <% end %>
           <% end %>
         </main>
 </div>