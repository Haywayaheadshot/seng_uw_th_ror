<div class="min-h-screen bg-gray-100">
  <header class="bg-blue-600 text-white p-4">
    <h1 class="text-2xl font-bold text-center md:text-left">Admin Dashboard</h1>
  </header>
  <main class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8">
    <p class="text-lg text-gray-700 mb-4">Welcome to the Participatory Budgeting Admin Dashboard</p>

    <h2 class="text-xl font-semibold mb-4">Active Voting Phases</h2>
    <% if @active_phases.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full bg-white shadow-md rounded-lg">
          <thead class="bg-gray-200">
            <tr>
              <th class="py-2 px-4 text-left">Budget Cycle</th>
              <th class="py-2 px-4 text-left">Phase Name</th>
              <th class="py-2 px-4 text-left">Status</th>
              <th class="py-2 px-4 text-left">Start Date</th>
              <th class="py-2 px-4 text-left">End Date</th>
              <th class="py-2 px-4 text-left">Voting Rules</th>
              <th class="py-2 px-4 text-left">Eligibility</th>
            </tr>
          </thead>
          <tbody>
            <% @active_phases.each do |phase| %>
              <tr class="border-b">
                <td class="py-2 px-4"><%= link_to phase.budget_cycle.name, admin_budget_cycle_voting_phases_path(phase.budget_cycle), class: "text-blue-500 hover:underline" %></td>
                <td class="py-2 px-4"><%= phase.name %></td>
                <td class="py-2 px-4"><%= humanize_phase_status(phase) %></td>
                <td class="py-2 px-4"><%= phase.start_date %></td>
                <td class="py-2 px-4"><%= phase.end_date %></td>
                <td class="py-2 px-4"><%= format_voting_rules(phase) %></td>
                <td class="py-2 px-4"><%= format_participant_eligibility(phase) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-gray-600">No active voting phases.</p>
    <% end %>

    <h2 class="text-xl font-semibold mt-8 mb-4">Budget Cycle Management</h2>
    <div class="mb-4">
      <%= link_to "Create New Budget Cycle", new_admin_budget_cycle_path, class: "block bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600 text-center md:text-left" %>
    </div>

    <h2 class="text-xl font-semibold mt-8 mb-4">All Budget Cycles</h2>
    <ul class="space-y-2">
      <% @budget_cycles.each do |cycle| %>
        <li>
          <%= link_to cycle.name, admin_budget_cycle_voting_phases_path(cycle), class: "block bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600 text-center md:text-left" %>
        </li>
      <% end %>
      <li>
        <%= link_to "Manage Budget Categories", admin_budget_categories_path, class: "block bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600 text-center md:text-left" %>
      </li>
    </ul>
  </main>
</div>