<%= render 'shared/nav' %>
<h2 class="text-xl font-semibold mb-2">Active Budget Cycles and Voting Phases</h2>
<% if @budget_cycles.empty? %>
  <p class="text-gray-500">No active budget cycles available.</p>
<% else %>
  <% @budget_cycles.each do |cycle| %>
    <div class="mb-4 p-4 border rounded bg-gray-50">
      <h3 class="text-lg font-medium">Budget Cycle: <%= cycle.name %></h3>
      <p>Total Budget: <%= number_to_currency(cycle.total_budget) %></p>
      <p>Active From: <%= cycle.start_date %> to <%= cycle.end_date %></p>
      <% phase = cycle.current_voting_phase %>
      <% if phase %>
        <p>Current Phase: <%= phase.name %> (<%= phase.phase_status.humanize %>)</p>
        <h4 class="mt-2 font-medium">Category Utilization</h4>
        <table class="table-auto w-full border-collapse">
          <thead>
            <tr class="bg-gray-200">
              <th class="border px-4 py-2">Category</th>
              <th class="border px-4 py-2">Spending Limit (%)</th>
              <th class="border px-4 py-2">Utilization (%)</th>
              <th class="border px-4 py-2">Allocated Amount</th>
            </tr>
          </thead>
          <tbody>
            <% cycle.budget_categories.each do |category| %>
              <tr>
                <td class="border px-4 py-2"><%= category.name %></td>
                <td class="border px-4 py-2"><%= category.spending_limit_percentage %></td>
                <td class="border px-4 py-2"><%= category.utilization_rate(cycle) %></td>
                <td class="border px-4 py-2"><%= number_to_currency(category.allocated_amount(cycle)) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-gray-500">No active voting phase.</p>
      <% end %>
    </div>
  <% end %>
<% end %>

<h2 class="text-xl font-semibold mb-2">Voting Phase Reports</h2>
<% if @voting_reports.empty? %>
  <p class="text-gray-500">No active voting phases available.</p>
<% else %>
  <%= render partial: 'voting_phase_report', collection: @voting_reports, as: :report %>
<% end %>