<p style="color: green"><%= notice %></p>

<% content_for :title, "Dashboards" %>

<h1>Dashboards</h1>

<p>
  This Dashboard route for users that are not admin.
  The admin route dashboard is '/admin/dashboards/index'
</p>

<div id="dashboards">
  <% @dashboards.each do |dashboard| %>
    <%= render dashboard %>
    <p>
      <%= link_to "Show this dashboard", dashboard %>
    </p>
  <% end %>
</div>

<%= link_to "New dashboard", new_dashboard_path %>
